<Window x:Class="EvalProUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EvalPro – Prüfungsbewertung"
        Height="768" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

<Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}">
            <DockPanel>
                <!-- Logo / App Title -->
                <Border DockPanel.Dock="Top" Padding="20,24,20,20">
                    <StackPanel>
                        <TextBlock Text="EvalPro" FontSize="24" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Prüfungsbewertung" FontSize="11" Foreground="#94A3B8"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <Border Height="1" Background="#334155" Margin="0,16,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Navigation Items -->
                <StackPanel DockPanel.Dock="Top" Margin="8,8,8,0">
                    <TextBlock Text="N A V I G A T I O N" FontSize="10" FontWeight="SemiBold" Foreground="#64748B"
                               Margin="16,8,0,12"/>

                    <RadioButton Style="{StaticResource NavButton}"
                                 Content="🏠  Übersicht"
                                 IsChecked="True"
                                 Command="{Binding NavigateHomeCommand}"
                                 GroupName="Nav"/>

                    <RadioButton Style="{StaticResource NavButton}"
                                 Content="👥  Prüfungsausschüsse"
                                 Command="{Binding NavigateCommitteesCommand}"
                                 GroupName="Nav"/>

                    <RadioButton Style="{StaticResource NavButton}"
                                 Content="🎓  Prüflinge"
                                 Command="{Binding NavigateExamineesCommand}"
                                 GroupName="Nav"/>
                </StackPanel>

                <!-- Footer -->
                <Border DockPanel.Dock="Bottom" Padding="16,12">
                    <TextBlock Text="© 2026 EvalPro" FontSize="11" Foreground="#475569"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- Spacer -->
                <Border/>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}"/>

    </Grid>
</Window>